import sqlite3
from datetime import datetime
import os

class ExportadorSQLServer:
    def __init__(self):
        # Mapeamento de tipos SQLite para SQL Server
        self.type_map = {
            'INTEGER': 'INT',
            'TEXT': 'NVARCHAR(MAX)',
            'REAL': 'FLOAT',
            'BLOB': 'VARBINARY(MAX)',
            'NUMERIC': 'DECIMAL(18,5)',
            'BOOLEAN': 'BIT',
            'DATE': 'DATE',
            'DATETIME': 'DATETIME2'
        }

    def map_type(self, sqlite_type):
        """Converte tipo SQLite para SQL Server"""
        sqlite_type = sqlite_type.upper()
        # Trata variações como VARCHAR(255) - se vier do SQLite, mas normalmente é TEXT
        if '(' in sqlite_type:
            base = sqlite_type.split('(')[0]
            if base in self.type_map:
                return sqlite_type  # mantém se já tem tamanho (ex: VARCHAR(255))
        return self.type_map.get(sqlite_type, 'NVARCHAR(MAX)')

    def exportar_para_sqlserver(self, caminho_banco_sqlite, pasta_saida='backups_sqlserver'):
        """
        Exporta banco SQLite para script SQL compatível com SQL Server
        """
        os.makedirs(pasta_saida, exist_ok=True)
        
        data_hora = datetime.now().strftime('%Y%m%d_%H%M%S')
        nome_arquivo = f"qstione_sqlserver_{data_hora}.sql"
        caminho_arquivo = os.path.join(pasta_saida, nome_arquivo)
        
        try:
            conn = sqlite3.connect(caminho_banco_sqlite)
            cursor = conn.cursor()
            
            with open(caminho_arquivo, 'w', encoding='utf-8') as f:
                # Cabeçalho
                f.write(f"-- Script de migração do Qstione para SQL Server\n")
                f.write(f"-- Gerado em: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
                f.write(f"-- Fonte: {os.path.basename(caminho_banco_sqlite)}\n")
                f.write(f"\n")
                
                # Desabilitar constraints temporariamente (opcional)
                f.write("-- Desabilitar verificações de chaves estrangeiras\n")
                f.write("EXEC sp_MSforeachtable 'ALTER TABLE ? NOCHECK CONSTRAINT ALL';\n")
                f.write("EXEC sp_MSforeachtable 'ALTER TABLE ? DISABLE TRIGGER ALL';\n\n")
                
                # Obter todas as tabelas
                cursor.execute("SELECT name FROM sqlite_master WHERE type='table'")
                tabelas = cursor.fetchall()
                
                for tabela_info in tabelas:
                    tabela = tabela_info[0]
                    
                    # Obter estrutura da tabela (CREATE TABLE original)
                    cursor.execute(f"SELECT sql FROM sqlite_master WHERE type='table' AND name='{tabela}'")
                    create_sql = cursor.fetchone()[0]
                    
                    # Obter informações das colunas via PRAGMA
                    cursor.execute(f"PRAGMA table_info({tabela})")
                    colunas_info = cursor.fetchall()
                    
                    # Construir CREATE TABLE para SQL Server
                    f.write(f"-- Tabela: {tabela}\n")
                    f.write(f"IF NOT EXISTS (SELECT * FROM sysobjects WHERE name='{tabela}' AND xtype='U')\n")
                    f.write(f"CREATE TABLE [{tabela}] (\n")
                    
                    colunas_def = []
                    primary_key = None
                    
                    for col in colunas_info:
                        col_name = col[1]
                        col_type = self.map_type(col[2])
                        not_null = "NOT NULL" if col[3] else "NULL"
                        default = col[4]
                        
                        # Verifica se é chave primária e autoincrement
                        if col[5] == 1:  # pk
                            # SQLite autoincrement é detectado pelo "AUTOINCREMENT" no create_sql
                            if "AUTOINCREMENT" in create_sql.upper():
                                col_def = f"    [{col_name}] INT IDENTITY(1,1) PRIMARY KEY"
                            else:
                                col_def = f"    [{col_name}] {col_type} {not_null}"
                                primary_key = col_name
                        else:
                            col_def = f"    [{col_name}] {col_type} {not_null}"
                            if default is not None:
                                # Tratar default value (simplificado)
                                col_def += f" DEFAULT {default}"
                        
                        colunas_def.append(col_def)
                    
                    # Se primary_key não for autoincrement, adicionar constraint PK
                    if primary_key:
                        colunas_def.append(f"    CONSTRAINT PK_{tabela} PRIMARY KEY ([{primary_key}])")
                    
                    f.write(",\n".join(colunas_def))
                    f.write("\n);\n\n")
                    
                    # Obter dados da tabela
                    cursor.execute(f"SELECT * FROM {tabela}")
                    registros = cursor.fetchall()
                    
                    if registros:
                        f.write(f"-- Dados da tabela {tabela} ({len(registros)} registros)\n")
                        
                        # Obter nomes das colunas
                        colunas_nomes = [col[1] for col in colunas_info]
                        colunas_nomes_str = ', '.join([f"[{c}]" for c in colunas_nomes])
                        
                        for registro in registros:
                            valores_formatados = []
                            for valor in registro:
                                if valor is None:
                                    valores_formatados.append("NULL")
                                elif isinstance(valor, str):
                                    # Escapar aspas simples (já feito)
                                    valor_escapado = valor.replace("'", "''")
                                    valores_formatados.append(f"N'{valor_escapado}'")  # Prefixo N para Unicode
                                elif isinstance(valor, (int, float)):
                                    valores_formatados.append(str(valor))
                                elif isinstance(valor, bytes):
                                    # Converter BLOB para hex
                                    valores_formatados.append(f"0x{valor.hex()}")
                                else:
                                    valores_formatados.append(f"N'{str(valor)}'")
                            
                            valores_sql = ', '.join(valores_formatados)
                            
                            f.write(f"INSERT INTO [{tabela}] ({colunas_nomes_str}) VALUES ({valores_sql});\n")
                    
                    f.write("\n")
                
                # Reabilitar constraints
                f.write("-- Reabilitar verificações\n")
                f.write("EXEC sp_MSforeachtable 'ALTER TABLE ? CHECK CONSTRAINT ALL';\n")
                f.write("EXEC sp_MSforeachtable 'ALTER TABLE ? ENABLE TRIGGER ALL';\n")
                
                f.write("\n-- Fim do script\n")
            
            cursor.close()
            conn.close()
            
            print(f"✓ Script SQL Server gerado: {caminho_arquivo}")
            return caminho_arquivo
            
        except Exception as e:
            print(f"✗ Erro ao gerar script: {e}")
            return None

